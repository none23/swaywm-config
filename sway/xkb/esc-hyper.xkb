xkb_keymap {
    xkb_keycodes {
        include "evdev+aliases(qwerty)"
    };

    xkb_types {
        include "complete"
    };

    xkb_compat {
        include "complete"
    };

    xkb_symbols {
        include "pc+us+ru:2+inet(evdev)+capslock(escape)+group(alt_space_toggle)"
        key <ESC> { [ Hyper_L ] };
        modifier_map Mod3 { <ESC> };
    };

    xkb_geometry {
        include "pc(pc105)"
    };
};
